{
  "name": "recuperar-historico-copilot",
  "displayName": "Recuperar Historico Copilot",
  "description": "Extensión para recuperar los chats previos con Copilot",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:recuperar-historico-copilot.recuperador"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "recuperar-historico-copilot.recuperador",
        "name": "historico",
        "fullName": "Recuperador Historico",
        "description": "Lee sesiones previas (.jsonl) de Copilot y recupera contexto relevante"
      }
    ],
    "commands": [
      {
        "command": "recuperar-historico-copilot.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/sqlite3": "^3.1.11",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "sqlite3": "^5.1.7"
  }
}
